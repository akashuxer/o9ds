{
  "name": "@arvo/js",
  "version": "1.0.0-dev.2",
  "description": "Arvo Design System vanilla JS component library",
  "license": "UNLICENSED",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./plugin": {
      "types": "./dist/plugin.d.ts",
      "import": "./dist/plugin.js",
      "require": "./dist/plugin.cjs"
    },
    "./auto": {
      "types": "./dist/auto.d.ts",
      "import": "./dist/auto.js",
      "require": "./dist/auto.cjs"
    }
  },
  "sideEffects": [
    "./dist/auto.js",
    "./dist/auto.cjs"
  ],
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build"
  },
  "dependencies": {
    "@arvo/core": "1.0.0-dev.2",
    "@arvo/tokens": "1.0.0-dev.2",
    "@arvo/styles": "1.0.0-dev.2",
    "@arvo/utils": "1.0.0-dev.2"
  },
  "peerDependencies": {
    "jquery": "^3.7.0"
  }
}

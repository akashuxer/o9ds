{
  "name": "@arvo/styles",
  "version": "1.0.0-dev.2",
  "description": "Arvo Design System shared SCSS mixins, component styles, and shared patterns",
  "license": "UNLICENSED",
  "private": false,
  "sideEffects": true,
  "exports": {
    ".": "./src/_index.scss",
    "./scss/*": "./src/*",
    "./mixins/*": "./src/mixins/*",
    "./base": "./src/base/_global.scss",
    "./css": "./dist/arvo.css",
    "./css/min": "./dist/arvo.min.css"
  },
  "files": [
    "src/",
    "dist/",
    "scripts/",
    "_index.scss"
  ],
  "scripts": {
    "build": "node scripts/build.mjs"
  },
  "dependencies": {
    "@arvo/tokens": "1.0.0-dev.2"
  }
}

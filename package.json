{
  "name": "arvo-website",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build:arvo-styles": "node vendor/@arvo/styles/scripts/build.mjs",
    "images:webp": "node scripts/optimize-public-png-to-webp.mjs",
    "images:audit": "node scripts/audit-public-images.mjs",
    "build": "npm run build:arvo-styles && vite build && npm run images:audit",
    "preview": "vite preview",
    "vendor:arvo": "node scripts/vendor-arvo.mjs",
    "generate:component-stubs": "node scripts/generate-component-stubs.mjs",
    "generate:o9con-icons": "node scripts/generate-o9con-icons.mjs",
    "sync:descriptors": "node scripts/sync-from-descriptors.mjs"
  },
  "dependencies": {
    "@arvo/assets": "file:./vendor/@arvo/assets",
    "@arvo/core": "file:./vendor/@arvo/core",
    "@arvo/js": "file:./vendor/@arvo/js",
    "@arvo/react": "file:./vendor/@arvo/react",
    "@arvo/styles": "file:./vendor/@arvo/styles",
    "@arvo/tokens": "file:./vendor/@arvo/tokens",
    "@arvo/utils": "file:./vendor/@arvo/utils",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "sass": "^1.99.0",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.3.6",
    "vite": "^5.0.0"
  }
}
